                    <TabItem Header="Adverts">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <WrapPanel Margin="12">
                                <Border Width="360" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Advert Loop"/>
                                        <CheckBox x:Name="AdvertsEnabledCheckBox"
                                                  Content="Enable repeating advert posts"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Advert Interval (ms)"/>
                                        <TextBox x:Name="AdvertIntervalMsTextBox" Text="120000"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Advert Channels (comma separated)"/>
