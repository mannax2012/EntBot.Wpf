                                                 VerticalScrollBarVisibility="Auto"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Pause Between Pet Calls (seconds)"/>
                                        <TextBox x:Name="PetCallPauseMsTextBox" Text="3"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Extra Delay Before Auto-Group (seconds)"/>
                                        <TextBox x:Name="PetAutoGroupDelayMsTextBox" Text="3"/>
