<Window x:Class="EntBot.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ent Bot Control Center"
        Width="1600"
        Height="920"
        MinWidth="1280"
        MinHeight="820"
        Background="#F3F6F8"
        Closing="MainWindow_OnClosing">
    <Window.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D9E2EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,18,18"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#183153"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#334E68"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#627D98"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="#0B6E4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0B6E4F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="#E6ECF2"/>
            <Setter Property="Foreground" Value="#183153"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="22"
                Background="#183153"
                CornerRadius="16">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Width="700">
                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="Ent Bot Control Center"/>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#D9E2EC"
                               TextWrapping="Wrap"
                               Text="Edit the bot settings here, start or stop the runtime, and watch the live console output without using the terminal."/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            HorizontalAlignment="Right">
                    <WrapPanel HorizontalAlignment="Right">
                        <Button x:Name="StartButton"
                                Style="{StaticResource PrimaryButton}"
                                Click="StartButton_OnClick"
                                Content="Start Bot"/>
                        <Button x:Name="StopButton"
                                Style="{StaticResource SecondaryButton}"
                                Click="StopButton_OnClick"
                                Content="Stop Bot"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Click="SaveButton_OnClick"
                                Content="Save Settings"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Click="ReloadButton_OnClick"
                                Content="Reload Settings"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Margin="0"
                                Click="ClearLogButton_OnClick"
                                Content="Clear Log"/>
                    </WrapPanel>

                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Right"
                               Foreground="#D9E2EC"
                               FontWeight="SemiBold"
                               Text="Status: Idle"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="2.8*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource SectionCard}"
                    Margin="0,0,16,0">
                <TabControl Background="Transparent">
                    <TabItem Header="General">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12"
                                        MaxWidth="420"
                                        HorizontalAlignment="Left">
                                <Border Style="{StaticResource SectionCard}"
                                        Margin="0,0,0,18">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Application"/>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Login Address"/>
                                        <TextBox x:Name="LoginAddressTextBox" Text="login.swg-starforge.com"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Login Port"/>
                                        <TextBox x:Name="LoginPortTextBox" Text="44553"/>

                                        <TextBlock Margin="0,14,0,0" Style="{StaticResource HintText}" Text="The desktop app writes a JSON settings file and starts the bundled Node bot with that file path."/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCard}"
                                        Margin="0">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Account"/>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Username"/>
                                        <TextBox x:Name="UsernameTextBox"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Password"/>
                                        <PasswordBox x:Name="PasswordBox"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Character"/>
                                        <TextBox x:Name="CharacterTextBox"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Performance">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <WrapPanel Margin="12">
                                <Border Width="360" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Performance Mode"/>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Performance Type"/>
                                        <ComboBox x:Name="PerformanceTypeComboBox" SelectedIndex="0">
                                            <ComboBoxItem Content="dance"/>
                                            <ComboBoxItem Content="music"/>
                                        </ComboBox>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Startup Command Pause (ms)"/>
                                        <TextBox x:Name="StartupCommandPauseMsTextBox" Text="3000"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Startup Delay (ms)"/>
                                        <TextBox x:Name="StartupDelayMsTextBox" Text="2500"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Loop Interval (ms)"/>
                                        <TextBox x:Name="IntervalMsTextBox" Text="3000"/>
                                    </StackPanel>
                                </Border>

                                <Border Width="360" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Default Commands"/>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Dance Command"/>
                                        <TextBox x:Name="DanceCommandTextBox" Text="/startdance exotic4"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Music Command"/>
                                        <TextBox x:Name="MusicCommandTextBox" Text="/startmusic starwars1"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Flourish Command"/>
                                        <TextBox x:Name="FlourishCommandTextBox" Text="/flourish 2"/>

                                        <CheckBox x:Name="AnnounceCommandsCheckBox"
                                                  Margin="0,16,0,0"
                                                  Content="Send a tell confirming the loop start"/>
                                        <CheckBox x:Name="AutoInviteOnTellCheckBox"
                                                  Margin="0,10,0,0"
                                                  Content="Auto invite users who send a tell"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Pets">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <WrapPanel Margin="12">
                                <Border Width="360" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Pet Automation"/>
                                        <CheckBox x:Name="PetAutoCallEnabledCheckBox"
                                                  Content="Enable pet auto-call on startup"/>
                                        <CheckBox x:Name="PetAutoGroupEnabledCheckBox"
                                                  Margin="0,10,0,0"
                                                  Content="Run /tellpet group after summon"/>
                                        <CheckBox x:Name="PetDiscoveryEnabledCheckBox"
                                                  Margin="0,10,0,0"
                                                  Content="Discover pet/control-device candidates"/>
                                        <CheckBox x:Name="PetDiscoveryDebugCheckBox"
                                                  Margin="0,10,0,0"
                                                  Content="Verbose discovery debug logging"/>
                                    </StackPanel>
                                </Border>

                                <Border Width="360" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Control Devices"/>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Pet Control Device IDs (comma separated)"/>
                                        <TextBox x:Name="PetControlDeviceIdsTextBox"
                                                 MinHeight="100"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Pet Call Radial ID"/>
                                        <TextBox x:Name="PetCallRadialIdTextBox" Text="44"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Pause Between Pet Calls (ms)"/>
                                        <TextBox x:Name="PetCallPauseMsTextBox" Text="3000"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Extra Delay Before Auto-Group (ms)"/>
                                        <TextBox x:Name="PetAutoGroupDelayMsTextBox" Text="3000"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Adverts">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <WrapPanel Margin="12">
                                <Border Width="360" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Advert Loop"/>
                                        <CheckBox x:Name="AdvertsEnabledCheckBox"
                                                  Content="Enable repeating advert posts"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Advert Interval (ms)"/>
                                        <TextBox x:Name="AdvertIntervalMsTextBox" Text="120000"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Advert Channels (comma separated)"/>
                                        <TextBox x:Name="AdvertChannelsTextBox" Text="planetSay"/>
                                    </StackPanel>
                                </Border>

                                <Border Width="520" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Advert Message"/>
                                        <TextBox x:Name="AdvertMessageTextBox"
                                                 MinHeight="220"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 Text="Buff service available in Mos Eisley Cantina. Come get your entertainer buffs."/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Connection">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <WrapPanel Margin="12">
                                <Border Width="360" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Connection Health"/>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Refresh Connection Every (minutes)"/>
                                        <TextBox x:Name="ConnectionRefreshIntervalMinutesTextBox" Text="30"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Connection Timeout (ms)"/>
                                        <TextBox x:Name="ConnectionTimeoutMsTextBox" Text="10000"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Failure Threshold"/>
                                        <TextBox x:Name="FailureThresholdTextBox" Text="3"/>

                                        <CheckBox x:Name="VerboseSwgLoggingCheckBox"
                                                  Margin="0,16,0,0"
                                                  Content="Verbose SWG protocol logging"/>
                                    </StackPanel>
                                </Border>

                                <Border Width="360" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Reconnect Backoff"/>
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Reconnect Base Delay (ms)"/>
                                        <TextBox x:Name="ReconnectBaseDelayMsTextBox" Text="5000"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Reconnect Max Delay (ms)"/>
                                        <TextBox x:Name="ReconnectMaxDelayMsTextBox" Text="60000"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Reconnect Jitter (ms)"/>
                                        <TextBox x:Name="ReconnectJitterMsTextBox" Text="1500"/>

                                        <TextBlock Margin="0,14,0,6" Style="{StaticResource FieldLabel}" Text="Reconnect Stable Reset (ms)"/>
                                        <TextBox x:Name="ReconnectStableResetMsTextBox" Text="300000"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Band Mode">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="18">
                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionTitle}" Text="Optional Entertainers JSON"/>
                                        <TextBlock Style="{StaticResource HintText}"
                                                   Text="Leave this blank for the single-entertainer fields in the other tabs. If you paste a JSON array here, it will be written as entBot.entertainers and used for band mode or per-entertainer overrides."/>
                                        <TextBox x:Name="BandModeJsonTextBox"
                                                 Margin="0,16,0,0"
                                                 MinHeight="360"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 FontSize="13"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource SectionCard}"
                    Margin="0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Console Log"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Margin="0,0,0,12"
                                   Text="This mirrors stdout and stderr from the existing Node bot runtime."/>
                    </StackPanel>

                    <TextBox x:Name="LogTextBox"
                             FontFamily="Consolas"
                             FontSize="13"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
