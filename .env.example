ENT_BOT_APP_NAME=EntBot
ENT_BOT_LOGIN_ADDRESS=login.swg-starforge.com
ENT_BOT_LOGIN_PORT=44553
ENT_BOT_USERNAME=YOUR_SWG_ACCOUNT_USERNAME
ENT_BOT_PASSWORD=YOUR_SWG_ACCOUNT_PASSWORD
ENT_BOT_CHARACTER=YourEntertainer

ENT_BOT_PERFORMANCE_TYPE=dance
ENT_BOT_PERFORMANCE_COMMAND=
ENT_BOT_PERFORMANCE_COMMANDS=
ENT_BOT_STARTUP_COMMANDS=
ENT_BOT_PET_AUTO_CALL_ENABLED=false
ENT_BOT_PET_AUTO_GROUP_ENABLED=false
ENT_BOT_PET_AUTO_GROUP_COMMAND=/tellpet group
ENT_BOT_PET_DISCOVERY_ENABLED=true
ENT_BOT_PET_DISCOVERY_DEBUG=false
ENT_BOT_PET_CONTROL_DEVICE_IDS=
ENT_BOT_PET_CALL_RADIAL_ID=44
ENT_BOT_PET_CALL_PAUSE_MS=3000
ENT_BOT_PET_AUTO_GROUP_DELAY_MS=3000
ENT_BOT_DANCE_COMMAND=/startdance exotic4
ENT_BOT_MUSIC_COMMAND=/startmusic starwars1
ENT_BOT_FLOURISH_COMMAND=/flourish 2
ENT_BOT_STARTUP_COMMAND_PAUSE_MS=3000
ENT_BOT_STARTUP_DELAY_MS=2500
ENT_BOT_INTERVAL_MS=3000
ENT_BOT_ANNOUNCE_COMMANDS=true
ENT_BOT_AUTO_INVITE_ON_TELL=false

ENT_BOT_ADVERTS_ENABLED=false
ENT_BOT_ADVERT_INTERVAL_MS=120000
ENT_BOT_ADVERT_CHANNELS=planetSay
ENT_BOT_ADVERT_MESSAGE=Buff service available in Mos Eisley Cantina. Come get your entertainer buffs.

ENT_BOT_CONNECTION_REFRESH_INTERVAL_MINUTES=30
ENT_BOT_CONNECTION_TIMEOUT_MS=10000
ENT_BOT_FAILURE_THRESHOLD=3
ENT_BOT_RECONNECT_BASE_DELAY_MS=5000
ENT_BOT_RECONNECT_MAX_DELAY_MS=60000
ENT_BOT_RECONNECT_JITTER_MS=1500
ENT_BOT_RECONNECT_STABLE_RESET_MS=300000
ENT_BOT_VERBOSE_SWG_LOGGING=false

# Optional band mode.
# Put the JSON directly in your real `.env` using `ENT_BOT_ENTERTAINERS=...`
# and keep it all on one line when you actually enable it.
#
# `ENT_BOT_STARTUP_COMMANDS` must be valid JSON if you use it, for example:
# ENT_BOT_STARTUP_COMMANDS=["/tellpet follow me","/say setup complete"]
#
# `ENT_BOT_PET_CONTROL_DEVICE_IDS` is a comma-separated list of pet control device object IDs.
# You can also set `petControlDeviceIds` as a JSON array per entertainer.
#
# Wrapped example:
# ENT_BOT_ENTERTAINERS=[
#   {
#     "character":"StarDancerOne",
#     "username":"acct_dancer_1",
#     "password":"pw_dancer_1",
#     "performanceType":"dance",
#     "petDiscoveryEnabled":true,
#     "petAutoCallEnabled":true,
#     "petAutoGroupEnabled":true,
#     "petControlDeviceIds":["123456789012345678","123456789012345679"],
#     "petCallRadialId":44,
#     "petCallPauseMs":3000,
#     "petAutoGroupDelayMs":3000,
#     "danceCommand":"/startdance exotic4",
#     "flourishCommand":"/flourish 2",
#     "startupCommandPauseMs":3000,
#     "intervalMs":3000,
#     "autoInviteOnTell":true
#   },
#   {
#     "character":"StarMusicianOne",
#     "username":"acct_music_1",
#     "password":"pw_music_1",
#     "performanceType":"music",
#     "petDiscoveryEnabled":true,
#     "petAutoCallEnabled":true,
#     "petAutoGroupEnabled":true,
#     "petControlDeviceIds":["223456789012345678"],
#     "musicCommand":"/startmusic starwars1",
#     "flourishCommand":"/flourish 3",
#     "startupCommands":["/say musician online"],
#     "intervalMs":4000,
#     "autoInviteOnTell":false
#   }
# ]
#
# Real one-line example:
# ENT_BOT_ENTERTAINERS=[{"character":"StarDancerOne","username":"acct_dancer_1","password":"pw_dancer_1","performanceType":"dance","danceCommand":"/startdance exotic4","flourishCommand":"/flourish 2","intervalMs":3000,"autoInviteOnTell":true},{"character":"StarMusicianOne","username":"acct_music_1","password":"pw_music_1","performanceType":"music","musicCommand":"/startmusic starwars1","flourishCommand":"/flourish 3","intervalMs":4000,"autoInviteOnTell":false}]
